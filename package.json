{
  "name": "faculty-evaluation-system",
  "version": "1.0.0",
  "scripts": {
    "start:backend": "cd Server && node server.js",
    "start:frontend": "cd client && npm start",
    "both": "concurrently --kill-others-on-fail \"npm run start:backend\" \"npm run start:frontend\"",
    "dev": "concurrently --kill-others-on-fail -n \"BACKEND,FRONTEND\" -c \"bgBlue.bold,bgGreen.bold\" \"npm run start:backend\" \"npm run start:frontend\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
